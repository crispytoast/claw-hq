  "private": true,
  "description": "OpenClaw plugin that backs Claw HQ \u2014 project-scoped chats, sub-project task toggles, file uploads, cross-device live feed.",
  "license": "UNLICENSED",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
